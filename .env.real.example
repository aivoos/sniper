# =============================================================================
# Contoh .env — RPC Solana nyata + host PumpPortal / PumpAPI (publik)
# Salin ke .env dan ganti secret (Helius, kunci PumpPortal, dll.). Jangan commit .env.
# =============================================================================
#
# HTTP trade — jalur utama di kode: PUMP_NATIVE=1 (internal/pumpnative)
#   • PumpPortal Lightning: POST https://pumpportal.fun/api/trade?api-key=KUNCI_ANDA
#   • PumpAPI: POST https://api.pumpapi.io (body JSON: action, publicKey, mint, …)
# Quote paralel (RaceQuote) memakai POST {base}/quote + {"mint"}; jika tidak tersedia, BUY/SELL native tetap dicoba.
# =============================================================================

# --- 1) Infrastruktur ---
REDIS_URL=127.0.0.1:6379

# RPC Solana (ganti YOUR_HELIUS_API_KEY — daftar di https://www.helius.dev/ )
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
# Failover (opsional): beberapa URL dipisah koma — dipakai untuk konfirmasi tx (getSignatureStatuses).
# RPC_URLS=https://mainnet.helius-rpc.com/?api-key=KEY1,https://...,https://...
RPC_STUB=0

# --- 2) Eksekusi Pump (HTTP) — URL resmi ---
PUMP_NATIVE=1
PUMPPORTAL_URL=https://pumpportal.fun/api/trade
PUMPAPI_URL=https://api.pumpapi.io
PUMPPORTAL_API_KEY=YOUR_PUMPPORTAL_API_KEY
# PUMP_WALLET_PUBLIC_KEY=   # wajib jika ingin race BUY lewat PumpAPI native
PUMP_SLIPPAGE=10
PUMPAPI_SLIPPAGE=20
PUMP_PRIORITY_FEE=0.00005

TRADE_SIZE=0.1
TIMEOUT_MS=1500

# --- 3) Recovery ---
RECOVERY_INTERVAL=10

# --- 4) Adaptive exit & monitor ---
GRACE_SECONDS=2
MIN_HOLD=5
MAX_HOLD=15
TP_PERCENT=7
SL_PERCENT=5
PANIC_SL=8
MOMENTUM_DROP=2.5
QUOTE_INTERVAL_MS=500

# --- 5) Laporan & Telegram (opsional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
REPORT_EVERY_N_TRADES=5
REPORT_INTERVAL_MIN=30
REPORT_LOAD_RECENT=200

# --- 6) Multi-bot (opsional) ---
# BOTS_JSON=

# --- 7) Profit guard ---
MAX_DAILY_LOSS=0.5
MIN_BALANCE=0.2
ENABLE_TRADING=true
MAX_DAILY_TRADES=0

# --- Governance jam (opsional) ---
# TZ=Asia/Jakarta
# ACTIVE_START_HOUR=20
# ACTIVE_END_HOUR=2

# --- 8) Production hazards (opsional) ---
# MIN_DUST=0.0001
# QUOTE_MAX_AGE_MS=1000
LOCK_TTL_MIN=12
# STALE_BALANCE_WAIT_MS=1500

# --- 9) Stream WebSocket (URL resmi — terpisah dari HTTP trade di atas) ---
# PumpPortal data API
PUMP_WS_URL=wss://pumpportal.fun/api/data
# Alternatif PumpAPI stream (pilih salah satu atau sesuai kebutuhan)
# PUMP_WS_URL=wss://stream.pumpapi.io

# Kunci API PumpPortal untuk WebSocket (jika dipakai oleh penyedia)
# PUMP_WS_URL=wss://pumpportal.fun/api/data?api-key=YOUR_PUMPPORTAL_API_KEY

# Subscribe PumpPortal (default internal jika kosong + host pumpportal)
# PUMP_WS_SUBSCRIBE_JSON=[{"method":"subscribeNewToken"},{"method":"subscribeMigration"}]

PUMP_WS_AUTO_HANDLE=false

# =============================================================================
# Referensi cepat (sumber: pumpportal.fun / pumpapi.io)
#   Trade Portal : https://pumpportal.fun/api/trade?api-key=YOUR_KEY
#   Trade PumpAPI: https://api.pumpapi.io
#   WS Portal    : wss://pumpportal.fun/api/data
#   WS PumpAPI   : wss://stream.pumpapi.io
# =============================================================================
