# Copy to .env and fill values (never commit .env)

REDIS_URL=redis:6379

RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Set to 1 for local testing without real RPC confirmation paths
RPC_STUB=0

PUMPPORTAL_URL=https://example-pump-portal/buy
PUMPAPI_URL=https://example-pump-api/buy

TRADE_SIZE=0.1
TIMEOUT_MS=1500
RECOVERY_INTERVAL=10

# PR-002 adaptive exit (see docs/rlangga-env-contract.md §4)
GRACE_SECONDS=2
MIN_HOLD=5
MAX_HOLD=15
TP_PERCENT=7
SL_PERCENT=5
PANIC_SL=8
MOMENTUM_DROP=2.5
QUOTE_INTERVAL_MS=500

# PR-003 — trade log + laporan (opsional)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
REPORT_EVERY_N_TRADES=5
REPORT_INTERVAL_MIN=30
REPORT_LOAD_RECENT=200

# PR-004 — multi-bot (optional JSON array; omit to use built-in bot-10s + bot-15s)
# BOTS_JSON=[{"name":"bot-10s","min_hold":5,"max_hold":10,"take_profit":7,"stop_loss":5,"panic_loss":8,"momentum_drop":2.5,"grace_seconds":2},{"name":"bot-15s","min_hold":5,"max_hold":15,"take_profit":8,"stop_loss":5,"panic_loss":8,"momentum_drop":3,"grace_seconds":2}]
