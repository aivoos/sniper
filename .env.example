# =============================================================================
# RLANGGA / sniper — salin ke .env dan isi nilai nyata (jangan commit .env)
# Referensi: docs/rlangga-env-contract.md
# Template RPC nyata + host PumpPortal/PumpAPI (publik): lihat .env.real.example
#
# cmd/worker memuat .env dari direktori kerja saat start (github.com/joho/godotenv).
# Variabel yang sudah di-export di shell tidak ditimpa oleh .env (default godotenv).
# =============================================================================

# --- 1) Infrastruktur (wajib untuk worker) ---
REDIS_URL=redis:6379
# Reset agregat PnL / daftar trade di Redis (bukan FLUSHDB): go run ./cmd/reset-pnl

# Mirror append trade tertutup ke file SQLite (opsional) untuk query SQL / tuning — lihat docs/sql/trades.sql
# TRADE_SQLITE_PATH=/data/rlangga/trades.sqlite
# Minimum snapshot dari stream (hanya mem-filter jika field ada di payload WSS): hindari entry terlalu tipis
# FILTER_MIN_INITIAL_BUY=0
# FILTER_MIN_ENTRY_MARKET_CAP_SOL=0
# FILTER_MIN_ENTRY_SOL_IN_POOL=0
# FILTER_MIN_BURNED_LIQUIDITY_PCT=0
# FILTER_REJECT_POOL_CREATED_BY_CUSTOM=0

# RPC Solana (wajib jika RPC_STUB=0)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Beberapa endpoint dipisah koma — failover otomatis saat konfirmasi tx (getSignatureStatuses).
# Jika di-set, daftar ini dipakai; tetap bisa mengisi RPC_URL pertama sebagai cadangan dokumentasi.
# RPC_URLS=https://mainnet.helius-rpc.com/?api-key=KEY1,https://...,https://...
# 1 = tanpa konfirmasi RPC nyata (uji lokal / stub)
RPC_STUB=0

# Paper / uji RPC nyata (opsional): PAPER_TRADE=1 + RPC_STUB=0. Repo ini mengarah ke mainnet, bukan devnet.
# HELIUS_API_KEY=   → jika PAPER_TRADE=1 dan RPC_URL kosong: URL Helius mainnet otomatis
# PAPER_TRADE=0
# Atau set RPC_URL / RPC_URLS mainnet (Helius dll.) tanpa mengandalkan variabel di atas.

# --- 2) Eksekusi Pump — URL resmi (PumpPortal + PumpAPI) ---
# Dokumentasi: https://pumpportal.fun/trading-api/  |  https://pumpapi.io/
# Jalur utama: Lightning + JSON native (internal/pumpnative) — set PUMP_NATIVE=1.
PUMP_NATIVE=1
PUMPPORTAL_URL=https://pumpportal.fun/api/trade
PUMPAPI_URL=https://api.pumpapi.io
PUMPPORTAL_API_KEY=YOUR_PUMPPORTAL_API_KEY
# PumpAPI JSON: disarankan base58 wallet (field privateKey). Alternatif: pubkey saja (legacy).
# PUMP_PRIVATE_KEY=
# PUMP_WALLET_PUBLIC_KEY=
# Opsional PumpAPI (dokumentasi pumpapi.io): quoteMint, poolId, fee dinamis, Jito, guaranteedDelivery
# PUMPAPI_QUOTE_MINT=
# PUMPAPI_POOL_ID=
# PUMPAPI_GUARANTEED_DELIVERY=0
# PUMPAPI_JITO_TIP=0
# PUMPAPI_MAX_PRIORITY_FEE=0
# PUMPAPI_PRIORITY_FEE_MODE=   # kosong = pakai angka PUMP_PRIORITY_FEE; mis. auto, auto-95, auto-75

# Quote paralel (RaceQuote): POST {base}/quote + body {"mint"} — bawaan kode.
# Jika provider tidak punya /quote persis itu, quote bisa gagal; BUY/SELL native tetap dipakai (lihat executor).
# PUMPPORTAL_QUOTE_URL=
# PUMPAPI_QUOTE_URL=

PUMP_SLIPPAGE=10
PUMPAPI_SLIPPAGE=20
PUMP_PRIORITY_FEE=0.00005

# Mode lama (gateway custom): POST {PUMPPORTAL_URL}/buy|/sell|/quote — tanpa PUMP_NATIVE / tanpa kunci Portal.
# PUMP_NATIVE=0
# PUMPPORTAL_URL=https://proxy-anda/basis-tanpa-path

TRADE_SIZE=0.1
TIMEOUT_MS=1500

# --- 3) Recovery loop ---
# Detik antar pemanggilan RecoverAll (scan wallet → force sell)
RECOVERY_INTERVAL=10

# --- 4) Adaptive exit & monitor (PR-002) ---
GRACE_SECONDS=2
MIN_HOLD=5
MAX_HOLD=15
TP_PERCENT=7
SL_PERCENT=5
PANIC_SL=8
MOMENTUM_DROP=2.5
QUOTE_INTERVAL_MS=500

# --- 5) Laporan & Telegram (PR-003, opsional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
REPORT_EVERY_N_TRADES=5
REPORT_INTERVAL_MIN=30
REPORT_LOAD_RECENT=200

# --- 6) Multi-bot (PR-004, opsional) ---
# Kosong = pakai profil bawaan bot-10s + bot-15s. Isi = JSON array profil.
# BOTS_JSON=[{"name":"bot-10s","min_hold":5,"max_hold":10,"take_profit":7,"stop_loss":5,"panic_loss":8,"momentum_drop":2.5,"grace_seconds":2},{"name":"bot-15s","min_hold":5,"max_hold":15,"take_profit":8,"stop_loss":5,"panic_loss":8,"momentum_drop":3,"grace_seconds":2}]

# --- 7) Profit guard — gate BUY saja (PR-005) ---
MAX_DAILY_LOSS=0.5
MIN_BALANCE=0.2
ENABLE_TRADING=true
# 0 = tidak ada batas kuota harian (BUY sukses)
MAX_DAILY_TRADES=0

# Jendela jam aktif untuk BUY baru (opsional; kosongkan keduanya = 24/7 untuk gate ini)
# TZ=Asia/Jakarta
# ACTIVE_START_HOUR=20
# ACTIVE_END_HOUR=2

# --- 7b) Filter entry stream + anti-rug — docs/filter-rug-honeypot.md
# Wajibkan field initialBuy dari payload WSS (event create / yang mengirim initialBuy); 0 = tidak wajib
# FILTER_REQUIRE_INITIAL_BUY=0
# FILTER_ANTI_RUG=0
# FILTER_REJECT_FREEZE_AUTHORITY=1
# FILTER_REJECT_MINT_AUTHORITY=0
# Holder terbesar (2 RPC ekstra). Default 0 = mati (prioritas early phase / latensi rendah). Contoh: 5 = tolak jika > 5%.
# FILTER_MAX_TOP_HOLDER_PCT=5
# FILTER_RPC_FAIL_OPEN=1

# --- 8) Production hazards (opsional, §7 env-contract) ---
# Abaikan sisa saldo di bawah ambang (recovery)
# MIN_DUST=0.0001
# Lewati tick monitor jika quote lebih tua dari ini (ms); 0 = mati
# QUOTE_MAX_AGE_MS=1000
# TTL lock mint (menit); default internal 12 jika kosong sesuai parse
LOCK_TTL_MIN=12
# Jeda (ms) antar token di recovery setelah SELL + laporan; 0 = mati
# STALE_BALANCE_WAIT_MS=1500

# --- 9) Stream WebSocket (opsional; terpisah dari HTTP trade/quote) ---
# Disarankan SATU sumber: PumpAPI stream — selaras dengan PUMPAPI_URL / filter txType / marketCap di payload.
# Primer + fallback paralel = dua koneksi (bisa duplikat mint); kosongkan fallback jika tidak perlu.
PUMP_WS_URL=wss://stream.pumpapi.io
# PUMP_WS_FALLBACK_URL=wss://pumpportal.fun/api/data

# Subscribe manual (JSON array) — hanya relevan untuk host PumpPortal. Stream PumpAPI: biasanya tanpa subscribe tambahan.
# PUMP_WS_SUBSCRIBE_JSON=[{"method":"subscribeNewToken"},{"method":"subscribeMigration"}]

# false = hanya terima pesan (callback internal tidak memicu trade). true = parse mint dari JSON → HandleMint (risiko tinggi).
PUMP_WS_AUTO_HANDLE=false

# Filter dari payload WSS sebelum HandleMint (hanya jika AUTO_HANDLE + setidaknya satu baris di bawah di-set). docs/wss-data-for-filters.md
# Profil minimal — filter venue saja (biarkan yang lain kosong/0):
# FILTER_WSS_POOL=pump,pump-amm
# Opsional — sempitkan lagi sinyal:
# FILTER_WSS_ALLOW_TX_TYPES=create
# FILTER_WSS_DENY_TX_TYPES=sell
# FILTER_WSS_ALLOW_METHODS=
# FILTER_WSS_MIN_SOL=0
# FILTER_WSS_MAX_SOL=0
# FILTER_WSS_MIN_MARKET_CAP_SOL=0
# FILTER_WSS_MAX_MARKET_CAP_SOL=0

# Stream data nyata + hanya log mint (tanpa mesin BUY/monitor): SIMULATE_TRADING=1 + PUMP_WS_AUTO_HANDLE=true.
# Setiap mint yang ter-parse log [SIM] (dedupe via Redis).
# SIMULATE_TRADING=0

# Mesin adaptif penuh tanpa transaksi on-chain: SIMULATE_ENGINE=1
# — guard/lock/idempotency, BUY/SELL di-skip (log [SIM-ENGINE]), monitor + exit rules jalan.
# Quote: pakai endpoint /quote jika PUMPPORTAL_URL/PUMPAPI_URL terisi; jika tidak, harga sintetis.
# Kuota harian / UpdateDailyLoss tidak diubah. Kombinasi dengan stream: SIMULATE_TRADING=0, SIMULATE_ENGINE=1.
# SIMULATE_ENGINE=0

# Quote sintetis (PnL paper) jika /quote HTTP tidak dipakai — 0 = default amplitudo 12% / periode 4s.
# SIMULATE_SYNTH_AMPLITUDE_PCT=15
# SIMULATE_SYNTH_PERIOD_SEC=6
# SIMULATE_SYNTH_DRIFT_PCT=0

# =============================================================================
# Detail env: docs/rlangga-env-contract.md
# Sim engine (stream nyata + tx simulasi + tuning PnL): docs/sim-engine-tuning.md
# =============================================================================
